  shorttitle = {Towards the Understanding of Heavy Quarks Hadronization},
  author = {Altmann, J. and Dubla, A. and Greco, V. and Rossi, A. and Skands, P.},
  year = 2025,
  month = jan,
  journal = {The European Physical Journal C},
  volume = {85},
  number = {1},
  eprint = {2405.19137},
  primaryclass = {hep-ph},
  pages = {16},
  issn = {1434-6052},
  doi = {10.1140/epjc/s10052-024-13641-5},
  urldate = {2026-04-14},
  abstract = {The formation of hadrons is a fundamental process in nature that can be investigated at particle colliders. As several recent findings demonstrate, with e+e- collisions as a ''vacuum-like'' reference at one extreme, and central nucleus--nucleus as a dense, extended-size system characterized by flow and local equilibrium at the opposite extreme, different collision systems offer a lever arm that can be exploited to probe with a range of heavy-flavour hadron species the onset of various hadronization processes. In this review, we present an overview of the theoretical and experimental developments. The focus is on open-heavy-flavour measurements. The comparison with model predictions and connections among the results in electron-positron, proton--proton, proton--nucleus, nucleus--nucleus collisions are discussed. After reviewing the current state, we suggest some prospects and future developments.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {High Energy Physics - Phenomenology,Nuclear Experiment,Nuclear Theory},
  file = {/Users/wax/Zotero/storage/7Q2B9J9C/Altmann et al. - 2025 - Towards the understanding of heavy quarks hadronization from leptonic to heavy-ion collisions.pdf}
}

