@phdthesis{zotero-item-1,
  type = {{{MSc Thesis}}},
  title = {Heavy {{Flavour Hadronisation}} and {{Balancing Studies}} as a {{Function}} of {{Multiplicity}} in Pp {{Collisions}} at the {{LHC}} with {{PYTHIA}} 8.3},
  shorttitle = {Heavy {{Flavour Hadronisation}} and {{Balancing Studies}}},
  author = {Veen, Paul},
  year = 2023,
  address = {Amsterdam, The Netherlands},
  abstract = {Hadronisation describes the formation of mesons and baryons from coloured partons. It is fundamental in understanding how matter is created directly after the Big Bang. It is described by Quantum Chromodynamics (QCD), which is non-perturbative at low energies. Unfortunately for us, hadronisation takes place in this non-perturbative region and therefore the study is limited to phenomenological models in Monte Carlo (MC) event generators. Previous studies have shown that these MC models have difficulty in predicting the creation of charm baryons. However, the Junctions hadronisation model of the PYTHIA MC generator shows a promising baryon increase and I extend these studies to beauty and charm quarks, including multiplicity dependence. I confirm the expected baryon increase in Junctions and I comment on differences in beauty and charm. An interesting peak-like behaviour is seen for the baryon/meson ratios as a function of multiplicity, which is not expected naively. My results mainly probe PYTHIA, though when the future ALICE upgrade is realised, these simulation studies can also be compared to data.},
  langid = {american},
  school = {Universiteit van Amsterdam; Vrije Universiteit Amsterdam},
  file = {/Users/wax/Zotero/storage/3ZX8ZTAA/Veen - 2023 - Heavy Flavour Hadronisation and Balancing Studies as a Function of Multiplicity in pp Collisions at.pdf}
}

